names=["Ramu","raju","Ravi"]
marks=[[45,55,90],[66,78.90],[67,88,98]]
for i in range(3):
    p=sum(marks[i])//3
    if p>80:
        g="S"
    elif p<40:
        g="F"
    elif p>40 and p<60:
        g="B"
    else:
        g="A"
    print("{}.Mr/Ms {} has scored {}% -{} Grade".format(i+1,names[i].title(),p,g))
